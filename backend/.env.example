# =============================================================================
# WaaS (Webhook-as-a-Service) Platform - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
#
# Docker Compose and Makefile targets read from this file automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:password@localhost:5432/webhook_platform?sslmode=disable
POSTGRES_DB=webhook_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# -----------------------------------------------------------------------------
# Cache / Queue (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_PORT=8080

# -----------------------------------------------------------------------------
# Analytics Service
# -----------------------------------------------------------------------------
ANALYTICS_PORT=8082

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Options: development, production
ENVIRONMENT=development
# Options: debug, info, warn, error
LOG_LEVEL=info
# Options: json, text
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Test Environment (used by Makefile.test)
# -----------------------------------------------------------------------------
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/webhook_platform_test?sslmode=disable
TEST_REDIS_URL=redis://localhost:6379/10
