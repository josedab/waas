# =============================================================================
# WaaS (Webhook-as-a-Service) Platform - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
#
# Docker Compose and Makefile targets read from this file automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:REPLACE_ME_OR_STARTUP_FAILS@localhost:5432/webhook_platform?sslmode=disable
POSTGRES_DB=webhook_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_OR_STARTUP_FAILS

# -----------------------------------------------------------------------------
# Cache / Queue (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_PORT=8080

# -----------------------------------------------------------------------------
# Analytics Service
# -----------------------------------------------------------------------------
ANALYTICS_PORT=8082

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_ME_OR_STARTUP_FAILS

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Options: development, production
ENVIRONMENT=development
# Options: debug, info, warn, error
LOG_LEVEL=info
# Options: json, text
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Test Environment (used by Makefile.test)
# -----------------------------------------------------------------------------
TEST_DATABASE_URL=postgres://postgres:REPLACE_ME_OR_STARTUP_FAILS@localhost:5432/webhook_platform_test?sslmode=disable
TEST_REDIS_URL=redis://localhost:6379/10

# -----------------------------------------------------------------------------
# AI / LLM Integration (optional)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# OpenTelemetry Observability (optional)
# -----------------------------------------------------------------------------
# OTEL_ENVIRONMENT=development
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_INSECURE=true
# OTEL_SERVICE_NAME=waas
# OTEL_SERVICE_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Stripe Billing Integration (optional)
# -----------------------------------------------------------------------------
# STRIPE_API_KEY=sk_test_...

# -----------------------------------------------------------------------------
# Platform Webhooks (optional)
# -----------------------------------------------------------------------------
# WEBHOOK_PLATFORM_API_KEY=your-platform-api-key

# -----------------------------------------------------------------------------
# WebSocket Configuration (optional)
# -----------------------------------------------------------------------------
# WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
