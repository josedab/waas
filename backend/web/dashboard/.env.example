# WaaS Dashboard Environment Variables
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env

# URL of the WaaS API service (used by the dashboard to make API requests).
# When running via `make run-dashboard`, this defaults to http://localhost:8080.
VITE_API_URL=http://localhost:8080

# WebSocket URL for real-time analytics (optional — Vite proxy handles this by default).
# VITE_WS_URL=ws://localhost:8082
