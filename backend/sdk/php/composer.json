{
    "name": "waas/waas-sdk",
    "description": "Official PHP SDK for the WAAS (Webhook-as-a-Service) Platform",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "WAAS Team",
            "email": "sdk@waas-platform.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "php-cs-fixer/shim": "^3.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "WAAS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WAAS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse src"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
