#!/usr/bin/env bash
# Pre-commit hook for WaaS platform
# Install with: make install-hooks

set -e

# Check for staged .env files or secrets
STAGED_ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.env($|\.)' || true)
if [ -n "$STAGED_ENV_FILES" ]; then
    echo "pre-commit: ❌ BLOCKED — .env file(s) staged for commit:"
    echo "$STAGED_ENV_FILES"
    echo ""
    echo "Remove with: git reset HEAD <file>"
    exit 1
fi

SECRET_PATTERNS='(password|secret|api_key|private_key|token)\s*[:=]\s*["\x27][^"\x27]{8,}'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED_FILES" ]; then
    SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -liE "$SECRET_PATTERNS" 2>/dev/null | grep -v -E '(\.example|\.sample|\.template|_test\.go|test_|mock_|fake_)' || true)
    if [ -n "$SECRETS_FOUND" ]; then
        echo "pre-commit: ⚠️  WARNING — possible secrets detected in:"
        echo "$SECRETS_FOUND"
        echo ""
        echo "Review these files carefully. Use 'git diff --cached <file>' to check."
        echo "If these are false positives (test fixtures, examples), proceed with: git commit --no-verify"
    fi
fi

# Only check staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

echo "pre-commit: checking staged Go files..."

# Check formatting
UNFORMATTED=$(gofmt -l $STAGED_GO_FILES)
if [ -n "$UNFORMATTED" ]; then
    echo "pre-commit: these files are not gofmt'd:"
    echo "$UNFORMATTED"
    echo ""
    echo "Run 'gofmt -w <file>' to fix, then re-stage."
    exit 1
fi

# Run go vet on packages containing staged files
PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -n1 dirname | sort -u | sed 's|^|./|')
if ! go vet $PACKAGES 2>&1; then
    echo "pre-commit: go vet found issues. Fix them before committing."
    exit 1
fi

echo "pre-commit: all checks passed."

# Optional: run golangci-lint on staged packages (non-blocking)
if command -v golangci-lint >/dev/null 2>&1; then
    LINT_PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -n1 dirname | sort -u | sed 's|^|./|')
    echo "pre-commit: running golangci-lint --fast on staged packages..."
    if ! golangci-lint run --fast $LINT_PACKAGES 2>&1; then
        echo ""
        echo "pre-commit: ⚠️  golangci-lint found issues (non-blocking)."
        echo "  Fix them before pushing, or CI will fail."
        echo "  To skip: git commit --no-verify"
    fi
fi

# Optional: run short tests on staged packages (non-blocking)
# Set WAAS_PRE_COMMIT_TEST=1 to enable, e.g.: export WAAS_PRE_COMMIT_TEST=1
if [ "${WAAS_PRE_COMMIT_TEST:-0}" = "1" ]; then
    TEST_PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -n1 dirname | sort -u | sed 's|^|./|')
    echo "pre-commit: running go test -short on staged packages..."
    if ! go test -short -count=1 $TEST_PACKAGES 2>&1; then
        echo ""
        echo "pre-commit: ⚠️  tests failed (non-blocking)."
        echo "  Fix before pushing, or CI will fail."
        echo "  Disable with: unset WAAS_PRE_COMMIT_TEST"
    fi
fi

# Validate .env.example completeness (advisory, non-blocking)
if [ -f .env.example ]; then
    ENV_VARS_IN_CODE=$(grep -roh 'os\.Getenv("[^"]*")' --include='*.go' . 2>/dev/null \
        | grep -v '_test\.go' \
        | sed 's/os\.Getenv("//;s/")//' \
        | grep -v -E '^(RUN_|TEST_)' \
        | sort -u)
    MISSING_VARS=""
    for var in $ENV_VARS_IN_CODE; do
        if ! grep -q "^${var}=" .env.example 2>/dev/null && ! grep -q "^# *${var}=" .env.example 2>/dev/null; then
            MISSING_VARS="$MISSING_VARS $var"
        fi
    done
    if [ -n "$MISSING_VARS" ]; then
        echo ""
        echo "pre-commit: ⚠️  These env vars are used in code but missing from .env.example:"
        for var in $MISSING_VARS; do
            echo "    $var"
        done
        echo "  Consider adding them to .env.example for contributor discoverability."
    fi
fi
