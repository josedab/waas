{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API Service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/api-service",
            "envFile": "${workspaceFolder}/backend/.env",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Delivery Engine",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/delivery-engine",
            "envFile": "${workspaceFolder}/backend/.env",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Analytics Service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/analytics-service",
            "envFile": "${workspaceFolder}/backend/.env",
            "cwd": "${workspaceFolder}/backend"
        }
    ],
    "compounds": [
        {
            "name": "All Services",
            "configurations": [
                "API Service",
                "Delivery Engine",
                "Analytics Service"
            ]
        }
    ]
}
